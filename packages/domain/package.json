{
  "name": "@tabipla/domain",
  "version": "0.1.0",
  "private": true,
  "description": "アプリ横断のドメイン定数・純粋関数（カテゴリ、エリア、収集上限など）。",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
