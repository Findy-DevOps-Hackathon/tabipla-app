# reindex（Postgres -> Elasticsearch）で使用する接続情報。
# 本番の認証情報はコミットしないこと。
DATABASE_URL=postgresql://tabipla:tabipla@localhost:5433/tabipla

# Elasticsearch 接続先（未設定なら search-core 側の既定 http://localhost:9200）。
# ES_NODE=http://localhost:9200

# ベクトル/ハイブリッド検索用 embedding 生成（embed-spots / POST /search/semantic）
# 既定: hash（API キー不要）。OpenAI を使う場合のみ以下も設定する。
EMBEDDING_PROVIDER=hash
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
