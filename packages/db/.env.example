# PostgreSQL 接続文字列（ローカル開発用の既定値）。
# 本番の認証情報はコミットしないこと。
DATABASE_URL=postgresql://tabipla:tabipla@localhost:5433/tabipla

# 管理画面シードユーザーのメールアドレス（seed 実行時・必須）
# admin-users.json の並び順に対応: _0, _1, ...
ADMIN_SEED_EMAIL_0=
ADMIN_SEED_EMAIL_1=

# 管理画面シードユーザーの初期パスワード（seed 実行時・必須）
ADMIN_SEED_PASSWORD_0=
ADMIN_SEED_PASSWORD_1=
