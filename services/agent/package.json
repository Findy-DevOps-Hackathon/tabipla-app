{
  "name": "@tabipla/agent",
  "version": "0.1.0",
  "private": true,
  "description": "ADKエージェント(推薦/蘊蓄/旅程/パーソナライズ)。@google/adk + Hono。検索は @tabipla/search-core に結線予定。",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "deploy": "bash scripts/deploy.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@google/adk": "^1.2.0",
    "@hono/node-server": "^1.19.0",
    "hono": "^4.12.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
