{
  "name": "@tabipla/backend-api",
  "version": "0.1.0",
  "private": true,
  "description": "アプリ用API。search-core 経由で Elasticsearch と連携する（ES へ直接アクセスしない）。",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "reindex": "tsx --env-file-if-exists=.env src/reindex.ts",
    "embed-spots": "tsx --env-file-if-exists=.env src/embed-spots.ts",
    "clean": "rm -rf dist",
    "deploy": "bash scripts/deploy.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@tabipla/db": "workspace:*",
    "@tabipla/maps-core": "workspace:*",
    "@tabipla/search-core": "workspace:*",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
