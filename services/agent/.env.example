# Vertex AI + ADC（Gemini モデル呼び出し。API キー不要）
# ローカル: gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-northeast1
# gemini-embedding-2 は global 専用。asia-northeast1 では 001 を使う。
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# backend-api（travel_times のフォールバック）
BACKEND_API_URL=http://localhost:3001

# backend-api からの呼び出し専用（Cloud Run 互換モード / ローカル開発）
AGENT_INTERNAL_SECRET=tabipla-dev-agent-internal-secret

# 本番: backend-api は AGENT_PLATFORM_RESOURCE で Reasoning Engine API を呼び出す
# AGENT_PLATFORM_RESOURCE=projects/.../locations/asia-northeast1/reasoningEngines/...
# AGENT_PLATFORM_LOCATION=asia-northeast1

# Elasticsearch（search ツール）
ES_NODE=http://localhost:9200

# スポットイラスト生成（Vertex 対応モデル。asia-northeast1 既定）
SPOT_IMAGE_MODEL=gemini-2.5-flash-image
# 画像モデルは regional 未提供のため global 既定（チャット等は GOOGLE_CLOUD_LOCATION）
SPOT_IMAGE_LOCATION=global
# 429 時のフォールバック先（省略時は global → us-central1 を自動試行）
# SPOT_IMAGE_LOCATION_FALLBACK=us-central1
# 旧プレビュー（リージョン未対応のため非推奨）:
# SPOT_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
# 参考写真モード:
#   auto（既定）= 調査 → 参考写真があれば photo、なければ text-only
#   text-only = 調査 + テキストのみ生成
#   photo = 調査 + 参考写真必須
# SPOT_IMAGE_REFERENCE_MODE=auto
# SPOT_IMAGE_REFERENCE_MODE=text-only
# SPOT_IMAGE_REFERENCE_MODE=photo
# 画像生成前の Google 調査（ビジュアルブリーフ）。既定 ON。0/false で無効
# SPOT_IMAGE_RESEARCH=1
# SPOT_IMAGE_RESEARCH=0

# 全エージェント共通の Gemini モデル。未設定時 gemini-3.5-flash
# GEMINI_CHAT_MODEL=gemini-3.5-flash
# AIガイドのみ別モデルにする場合:
# INTRODUCE_MODEL=gemini-3.5-flash
