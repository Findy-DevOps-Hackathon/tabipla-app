{
  "name": "@tabipla/maps-core",
  "version": "0.1.0",
  "description": "Google Maps Routes API を用いた移動時間・距離計算ライブラリ（A4 getTravelTimes）",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "verify": "node --env-file-if-exists=.env scripts/verify-routes.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^7.0.0"
  }
}
