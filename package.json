{
  "name": "tabipla-app",
  "version": "0.0.0",
  "private": true,
  "description": "tabipla モノレポ。検索基盤は packages/search-core に集約する。",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm --filter './packages/*' build && pnpm -r typecheck",
    "build": "pnpm -r build",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci:check": "pnpm check && pnpm typecheck && pnpm run audit",
    "ci:fix": "pnpm check:fix && pnpm ci:check",
    "audit": "pnpm audit --audit-level=high",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "dev:user": "bash scripts/dev-user-stack.sh",
    "figma:fetch": "node scripts/figma/fetch-design.mjs",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.4"
    }
  }
}
