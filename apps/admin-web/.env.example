# backend-api プロキシ先（開発時）
# VITE_API_PROXY_TARGET=http://localhost:3001

# 本番 API（Firebase Hosting デプロイ時。`.env.production` 参照）
# VITE_API_BASE=https://tabipla-backend-api-xxxxx-uc.a.run.app

# Google Maps JavaScript API（地図プレビュー）
# 取得: https://console.cloud.google.com/ → 認証情報
# 有効化: Maps JavaScript API
# 本番では HTTP リファラー制限を設定すること
VITE_GOOGLE_MAPS_API_KEY=
