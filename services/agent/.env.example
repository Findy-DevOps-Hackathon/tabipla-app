# Vertex AI (GCP) 経由で Gemini を使う（無料枠制限を回避）
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# gemini-3.5-flash は us-central1 非対応。asia-northeast1 / global / us / eu を使う
GOOGLE_CLOUD_LOCATION=asia-northeast1
# Gemini 3.x 専用リージョン（GOOGLE_CLOUD_LOCATION が非対応のとき自動フォールバック先）
# GEMINI_VERTEX_LOCATION=asia-northeast1

# backend-api（travel_times のフォールバック）
BACKEND_API_URL=http://localhost:3001

# Elasticsearch（search ツール）
ES_NODE=http://localhost:9200

# スポットイラスト生成（Gemini 3 Pro Image / Nano Banana Pro）。既定 gemini-3-pro-image
# SPOT_IMAGE_MODEL=gemini-3-pro-image
# SPOT_IMAGE_MODEL=gemini-3.1-flash-image
# gemini-3-pro-image は Vertex AI では global のみ。未設定時も global を使う
# SPOT_IMAGE_LOCATION=global
# 参考写真モード:
#   auto（既定）= 調査 → 参考写真があれば photo、なければ text-only
#   text-only = 調査 + テキストのみ生成
#   photo = 調査 + 参考写真必須
# SPOT_IMAGE_REFERENCE_MODE=auto
# SPOT_IMAGE_REFERENCE_MODE=text-only
# SPOT_IMAGE_REFERENCE_MODE=photo
# 画像生成前の Google 調査（ビジュアルブリーフ）。既定 ON。0/false で無効
# SPOT_IMAGE_RESEARCH=1
# SPOT_IMAGE_RESEARCH=0

# 全エージェント共通の Gemini モデル。未設定時 gemini-3.5-flash
# GEMINI_CHAT_MODEL=gemini-3.5-flash
# AIガイドのみ別モデルにする場合:
# INTRODUCE_MODEL=gemini-3.5-flash
