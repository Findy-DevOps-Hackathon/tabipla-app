# Google Maps Routes API キー
# 取得: https://console.cloud.google.com/ → 認証情報 → API キーを作成
# 有効化すべきAPI: Routes API (https://console.cloud.google.com/apis/library/routes.googleapis.com)
# 本番環境では Secret Manager で管理し、このファイルにキーを書かないこと。
GOOGLE_MAPS_API_KEY=

# destinations の最大件数（既定 25）。Routes API の課金・レイテンシ抑制のため変更に注意。
# MAX_DESTINATIONS=25
