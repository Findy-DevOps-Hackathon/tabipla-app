{
  "name": "@tabipla/db",
  "version": "0.1.0",
  "private": true,
  "description": "アプリのマスターデータ用 DB 層。Drizzle ORM + PostgreSQL。spots を管理し、search-core 経由で Elasticsearch へ reindex する元データを保持する。",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "drizzle",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx --env-file-if-exists=.env src/seed.ts",
    "seed:export": "tsx --env-file-if-exists=.env src/seedExport.ts",
    "backfill:noto-areas": "tsx --env-file-if-exists=.env src/backfillNotoSpotAreas.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
