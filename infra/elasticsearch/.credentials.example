# Copy to infra/elasticsearch/.credentials and fill in (DO NOT COMMIT)
# Elastic Cloud: Deployments → 対象デプロイ → Elasticsearch endpoint

ES_NODE=https://YOUR_DEPLOYMENT.es.asia-northeast1.gcp.cloud.es.io:443

# API キー認証（推奨）。Elastic Cloud → Security → API keys
ES_API_KEY=

# Basic 認証（API キーの代わりに使う場合）
# ES_USERNAME=elastic
# ES_PASSWORD=

# 任意（既定値で足りる場合は空でよい）
# ES_INDEX=spots
# ES_VECTOR_DIMS=1536
