# backend-api プロキシ先（開発時）
# VITE_API_PROXY_TARGET=http://localhost:3001

# agent プロキシ先（開発時）
# VITE_AGENT_PROXY_TARGET=http://localhost:8080

# 本番 API / agent（deploy.sh が tabipla-user-web 東京 Cloud Run URL を自動取得）
# VITE_API_BASE=https://tabipla-backend-api-xxxxx.asia-northeast1.run.app
# VITE_AGENT_BASE=https://tabipla-agent-xxxxx.asia-northeast1.run.app
