# PostgreSQL（Cloud SQL セットアップ後は infra/cloud-sql/.credentials を参照）
DATABASE_URL=postgresql://tabipla:tabipla@localhost:5433/tabipla
# Cloud Run 用例:
# DATABASE_URL=postgresql://tabipla:PASSWORD@/tabipla?host=/cloudsql/tabipla-user-web:asia-northeast1:tabipla-db
# CLOUD_SQL_INSTANCE=tabipla-user-web:asia-northeast1:tabipla-db

# Elasticsearch 接続先（未設定なら search-core 側の既定 http://localhost:9200）。
# ES_NODE=https://xxx.es.region.cloud.es.io:443
# ES_API_KEY=...

# ベクトル次元数（Gemini outputDimensionality と ES mapping を一致させる。既定 1536）
# ES_VECTOR_DIMS=1536

# Vertex AI Embeddings（Cloud Run の既定。サービスアカウント / ADC で認証）
# Cloud Run では GOOGLE_CLOUD_PROJECT をデプロイスクリプトが自動設定する。
# ローカルでは `gcloud auth application-default login` 後に設定する。
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# VERTEX_EMBEDDING_LOCATION=us-central1
# VERTEX_EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_PROVIDER=vertex

# Gemini API を使う移行検証・ローカル開発用の互換設定
# Google AI Studio: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# EMBEDDING_PROVIDER=gemini
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# API キーなしのローカル配線確認用（意味的類似度は限定的）
# EMBEDDING_PROVIDER=hash

# 管理画面: Places API（スポット名 → 住所の自動補完）
# 取得: https://console.cloud.google.com/ → 認証情報
# 有効化: Places API
GOOGLE_MAPS_API_KEY=

# 管理画面ログイン（JWT 署名鍵。本番では必ず変更）
ADMIN_JWT_SECRET=tabipla-dev-admin-secret

# Firebase Hosting（admin / user）からの CORS 許可オリジン（カンマ区切り）
# CORS_ORIGINS=https://tabipla-admin-web.web.app,https://tabipla-admin-web.firebaseapp.com,https://tabipla-user-web.web.app,https://tabipla-user-web.firebaseapp.com

# AIエージェントサービス（ローカル開発時は agent :8080）
AGENT_API_URL=http://localhost:8080

# AIエージェントサービス（Cloud Run デプロイ後の URL）
# AGENT_API_URL=https://tabipla-agent-xxxxx-an.a.run.app

# backend-api → agent のサービス間認証（本番では必ず変更）
AGENT_INTERNAL_SECRET=tabipla-dev-agent-internal-secret

# ES 同期 outbox のバックグラウンド再試行（既定: 有効、30秒間隔、20件/バッチ）
# ES_SYNC_WORKER_ENABLED=true
# ES_SYNC_RETRY_INTERVAL_MS=30000
# ES_SYNC_BATCH_SIZE=20

# スポット画像 GCS（本番推奨。未設定時はローカル data/uploads/spots）
# bash infra/gcs/setup.sh 実行後、infra/gcs/.credentials を参照
# GCS_BUCKET=your-project-spot-images
# GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/your-project-spot-images
# GCS_OBJECT_PREFIX=spots
